# חובה בפרודקשן ל־SEO: כתובת האתר המלאה ללא סלאש בסוף (canonical, sitemap, robots, OG)
# ב-Netlify: Environment variables → הוסיפו VITE_SITE_URL=https://הדומיין-שלכם
VITE_SITE_URL=https://royalfruit.co.il

# אופציונלי — מזהה Google Analytics 4; כשממולא מוצג באנר הסכמה לעוגיות
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# אופציונלי — השלמת כתובות בסל באמצעות Google Places Autocomplete
# יש להפעיל Places API ולהגביל את המפתח לדומיין האתר ב-Google Cloud
# VITE_GOOGLE_MAPS_API_KEY=AIza...

# מוצרים מ-Google Sheets — עמודות חובה: name, price, category, available
# מומלץ (בלי חשיפת כתובת הגיליון ב-JavaScript של הגלישה):
VITE_PRICE_SHEET_VIA_PROXY=1
# כתובת לייצוא CSV — משתנה שרת; ב-local כותבים ב-.env (לא מוטמע ב-bundle)
# GOOGLE_SHEETS_PRODUCTS_CSV_URL=https://docs.google.com/spreadsheets/d/e/2PACX-.../pub?output=csv
# ב-dev, Vite מגיש את /price-sheet.csv ומושך מ-GOOGLE_ או מ-VITE_GOOGLE_ (ראו vite.config.ts).
# בדיקה מהטלפון על אותה רשת WiFi: הריצו npm run dev:lan ופתחו את הכתובת http://<IP-של-המחשב>:5173 (לא localhost).
# ב-Netlify: הגדירו GOOGLE_SHEETS_PRODUCTS_CSV_URL בממשק + VITE_PRICE_SHEET_VIA_PROXY=1 בבנייה.
#
# Render.com — אין Netlify Functions: השתמשו ב-Web Service עם Start: node server.mjs (ראו render.yaml),
# ובסביבה: GOOGLE_SHEETS_PRODUCTS_CSV_URL (בזמן ריצה) + במהלך build: VITE_PRICE_SHEET_VIA_PROXY=1 + VITE_SITE_URL.
#
# מצב ישן (חושף URL/נתיב גיליון בבקשות הדפדפן): בלי VITE_PRICE_SHEET_VIA_PROXY, רק:
# VITE_GOOGLE_SHEETS_PRODUCTS_CSV_URL=https://docs.google.com/...
# VITE_GOOGLE_SHEETS_DIRECT=1

# וידג'ט נגישות חיצוני (נגיש בקליק וכדומה) — כתובת מלאה לסקריפט שקיבלתם מהספק
# VITE_ACCESSIBILITY_VENDOR_SCRIPT_URL=https://...
# אופציונלי — מאפיני data-* על תג ה־script במבנה JSON:
# VITE_ACCESSIBILITY_VENDOR_SCRIPT_DATASET={"sitekey":"..."}
